* text=auto

# Declare files that will always have LF line endings on checkout.
*.sh           text eol=lf
*.json         text eol=lf
*.js           text eol=lf
*.jsx          text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.css          text eol=lf
*.html         text eol=lf
*.md           text eol=lf
Dockerfile     text eol=lf

# Denote binary files
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.svg          text eol=lf
*.pdf          binary
*.woff         binary
*.woff2        binary
*.eot          binary
*.ttf          binary
