# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ─── PostgreSQL (Local Docker) ────────────────────────────────────────────────
# Start Docker first: docker compose up -d  (from project root)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# ─── PostgreSQL (Neon Cloud — production/deployment) ──────────────────────────
# Comment out DATABASE_URL above and uncomment this when deploying
# Get your connection string from https://neon.tech → your project → Connection Details
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/neondb?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a strong random secret (min 64 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Must match the URL your frontend runs on
CLIENT_URL=http://localhost:5173

# ─── Brevo Email Service (SMTP) ───────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-registered-email@example.com
BREVO_SMTP_PASS=your-brevo-smtp-key
BREVO_EMAIL_FROM=no-reply@assetflow.com

# ─── Twilio WhatsApp Service ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+919999999999
